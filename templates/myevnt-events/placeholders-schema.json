{
  "version": 1,
  "fields": [
    { "key": "vorname",  "label": "Vorname",  "type": "text", "required": true,  "placeholder_text": "z. B. Anna",  "default_value": "Vorname",  "max_length": 30, "options": [], "card_options": [], "section": "Profil", "order": 1 },
    { "key": "nachname", "label": "Nachname", "type": "text", "required": true,  "placeholder_text": "z. B. Müller", "default_value": "Nachname", "max_length": 30, "options": [], "card_options": [], "section": "Profil", "order": 2 },
    { "key": "profilbild", "label": "Profilbild", "type": "image", "required": false, "placeholder_text": "Quadratisch, min. 400×400 px", "default_value": "https://finestsites.vercel.app/placeholders/profilbild.webp", "max_length": null, "options": [], "card_options": [], "section": "Profil", "aspect_ratio": "1/1", "order": 3 },
    { "key": "headline", "label": "Headline", "type": "text", "required": false, "placeholder_text": "Ein kurzer Satz, was Besucher erwartet", "default_value": "Lerne mich live kennen. Online und vor Ort.", "max_length": 120, "options": [], "card_options": [], "section": "Profil", "order": 4 },
    { "key": "bio", "label": "Kurze Bio", "type": "textarea", "required": false, "placeholder_text": "Wer bist du? 2–4 Sätze, persönlich.", "default_value": "", "max_length": 600, "options": [], "card_options": [], "section": "Profil", "order": 5 },

    { "key": "instagram", "label": "Instagram (optional)",     "type": "url", "required": false, "placeholder_text": "https://instagram.com/...",      "default_value": "", "max_length": null, "options": [], "card_options": [], "section": "Profil", "order": 6 },
    { "key": "tiktok",    "label": "TikTok (optional)",        "type": "url", "required": false, "placeholder_text": "https://tiktok.com/@...",         "default_value": "", "max_length": null, "options": [], "card_options": [], "section": "Profil", "order": 7 },
    { "key": "youtube",   "label": "YouTube (optional)",       "type": "url", "required": false, "placeholder_text": "https://youtube.com/@...",        "default_value": "", "max_length": null, "options": [], "card_options": [], "section": "Profil", "order": 8 },
    { "key": "linkedin",  "label": "LinkedIn (optional)",      "type": "url", "required": false, "placeholder_text": "https://linkedin.com/in/...",     "default_value": "", "max_length": null, "options": [], "card_options": [], "section": "Profil", "order": 9 },
    { "key": "website",   "label": "Website / Link (optional)","type": "url", "required": false, "placeholder_text": "https://...",                     "default_value": "", "max_length": null, "options": [], "card_options": [], "section": "Profil", "order": 10 },

    {
      "key": "modus", "label": "Modus", "type": "card_select", "required": true,
      "placeholder_text": "", "default_value": "dunkel", "max_length": null, "options": [],
      "section": "Design", "order": 11,
      "card_options": [
        { "value": "dunkel", "label": "Dunkel", "description": "Cinematic, hoher Kontrast.", "card_type": "color", "color": "#0A0A0A", "image_url": "", "icon": "M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9z" },
        { "value": "hell",   "label": "Hell",   "description": "Klar, hell, freundlich.",     "card_type": "color", "color": "#F59E0B", "image_url": "", "icon": "M12 17a5 5 0 1 0 0-10 5 5 0 0 0 0 10zM12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" }
      ]
    },
    { "key": "akzentfarbe", "label": "Akzentfarbe", "type": "color", "required": true, "placeholder_text": "#7C3AED", "default_value": "#7C3AED", "max_length": null, "options": [], "card_options": [], "section": "Design", "order": 12 },

    {
      "key": "events", "label": "Events", "type": "loop", "required": false,
