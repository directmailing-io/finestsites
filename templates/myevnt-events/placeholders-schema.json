          "card_options": [
            { "value": "veroeffentlicht", "label": "Veröffentlicht", "description": "Live auf deiner Seite sichtbar.", "card_type": "color", "color": "#10B981", "image_url": "" },
            { "value": "entwurf",         "label": "Entwurf",         "description": "Nur für dich sichtbar.",          "card_type": "color", "color": "#6B7280", "image_url": "" }
          ]
        },

        {
          "key": "typ", "label": "Art des Events", "type": "card_select", "required": true,
          "default_value": "vor_ort",
          "card_options": [
            { "value": "vor_ort", "label": "Vor Ort", "description": "Live in echt, mit Adresse und Maps-Link.", "card_type": "color", "color": "#F97066", "image_url": "", "icon": "M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0zM12 13a3 3 0 1 0 0-6 3 3 0 0 0 0 6z" },
            { "value": "online",  "label": "Online",  "description": "Digital via Zoom, Meet oder Stream-Link.",  "card_type": "color", "color": "#3B82F6", "image_url": "", "icon": "M23 7 16 12l7 5V7zM1 5h15v14H1z" }
          ]
        },

