{
  "version": 1,
  "fields": [
    {
      "key": "vorname",
      "label": "Vorname",
      "type": "text",
      "required": true,
      "placeholder_text": "z. B. Anna",
      "default_value": "Vorname",
      "max_length": 30,
      "options": [],
      "card_options": [],
      "section": "Profil",
      "order": 1
    },
    {
      "key": "nachname",
      "label": "Nachname",
      "type": "text",
      "required": true,
      "placeholder_text": "z. B. Müller",
      "default_value": "Nachname",
      "max_length": 30,
      "options": [],
      "card_options": [],
      "section": "Profil",
      "order": 2
    },
    {
      "key": "profilbild",
      "label": "Profilbild",
      "type": "image",
      "required": false,
      "placeholder_text": "Quadratisch, min. 400×400 px",
      "default_value": "https://finestsites.vercel.app/placeholders/profilbild.webp",
      "max_length": null,
      "options": [],
      "card_options": [],
      "section": "Profil",
      "aspect_ratio": "1/1",
      "order": 3
    },
    {
      "key": "headline",
      "label": "Headline (optional)",
      "type": "text",
      "required": false,
      "placeholder_text": "Ein kurzer Satz, was Besucher erwartet",
      "default_value": "Lerne mich live kennen. Online und vor Ort.",
      "max_length": 100,
      "options": [],
      "card_options": [],
      "section": "Profil",
      "order": 4
    },
    {
      "key": "modus",
      "label": "Modus",
      "type": "card_select",
      "required": true,
      "placeholder_text": "",
      "default_value": "dunkel",
      "max_length": null,
      "options": [],
      "card_options": [
        { "value": "dunkel", "label": "Dunkel", "description": "Cinematic, hoher Kontrast.", "card_type": "color", "color": "#0A0A0A", "image_url": "" },
        { "value": "hell",   "label": "Hell",   "description": "Klar, hell, freundlich.",  "card_type": "color", "color": "#FFFFFF", "image_url": "" }
      ],
      "section": "Design",
      "order": 5
    },
    {
      "key": "akzentfarbe",
      "label": "Akzentfarbe",
      "type": "color",
      "required": true,
      "placeholder_text": "#7C3AED",
      "default_value": "#7C3AED",
      "max_length": null,
      "options": [],
      "card_options": [],
      "section": "Design",
      "order": 6
    },
    {
      "key": "events",
      "label": "Events",
      "type": "loop",
      "required": false,
      "placeholder_text": "Lege deine Events an",
      "default_value": "",
      "max_length": null,
      "options": [],
      "card_options": [],
      "section": "Events",
      "min_items": 0,
      "max_items": 50,
      "order": 7,
      "sub_fields": [
        { "key": "name",       "label": "Eventname", "type": "text", "required": true, "max_length": 60, "placeholder_text": "z. B. Teamcall, Powerday, Infocall" },
        { "key": "kuerzel",    "label": "Kürzel (für die URL)", "type": "text", "required": true, "max_length": 30, "placeholder_text": "z. B. powerday-juni" },
        {
          "key": "status",
          "label": "Status",
          "type": "card_select",
          "required": true,
          "default_value": "veroeffentlicht",
          "card_options": [
            { "value": "veroeffentlicht", "label": "Veröffentlicht", "description": "Live auf deiner Seite sichtbar.", "card_type": "color", "color": "#10B981", "image_url": "" },
            { "value": "entwurf",         "label": "Entwurf",         "description": "Nur für dich sichtbar, nicht öffentlich.", "card_type": "color", "color": "#6B7280", "image_url": "" }
          ]
        },
        {
          "key": "typ",
          "label": "Art des Events",
          "type": "card_select",
          "required": true,
          "default_value": "vor_ort",
          "card_options": [
            { "value": "vor_ort", "label": "Vor Ort",  "description": "Live in echt, mit Adresse und Maps-Link.", "card_type": "color", "color": "#F97066", "image_url": "" },
            { "value": "online",  "label": "Online",   "description": "Digital via Zoom, Meet oder Stream-Link.",   "card_type": "color", "color": "#3B82F6", "image_url": "" }
          ]
        },
        { "key": "titelbild",  "label": "Titelbild (Banner)", "type": "image", "required": false, "aspect_ratio": "16/9", "placeholder_text": "Querformat, 16:9" },
        { "key": "datum",      "label": "Datum (Start)",  "type": "date", "required": true, "placeholder_text": "" },
        { "key": "datum_ende", "label": "Datum Ende (optional, mehrtägig)", "type": "date", "required": false, "placeholder_text": "" },
        { "key": "uhrzeit",      "label": "Uhrzeit (Start)", "type": "time", "required": true, "placeholder_text": "" },
        { "key": "uhrzeit_ende", "label": "Uhrzeit Ende (optional)", "type": "time", "required": false, "placeholder_text": "" },
        {
          "key": "wiederkehrung",
          "label": "Wiederkehrung",
          "type": "card_select",
          "required": true,
          "default_value": "einmalig",
          "card_options": [
            { "value": "einmalig",      "label": "Einmalig",      "description": "Findet genau einmal statt.",      "card_type": "color", "color": "#A78BFA", "image_url": "" },
            { "value": "taeglich",      "label": "Täglich",       "description": "Jeden Tag zur gleichen Zeit.",    "card_type": "color", "color": "#F59E0B", "image_url": "" },
            { "value": "woechentlich",  "label": "Wöchentlich",   "description": "Jede Woche zur gleichen Zeit.",   "card_type": "color", "color": "#10B981", "image_url": "" },
            { "value": "monatlich_1x",  "label": "1× pro Monat",  "description": "Einmal im Monat.",                "card_type": "color", "color": "#06B6D4", "image_url": "" },
            { "value": "monatlich_2x",  "label": "2× pro Monat",  "description": "Zweimal im Monat.",               "card_type": "color", "color": "#0EA5E9", "image_url": "" },
            { "value": "individuell",   "label": "Individuell",   "description": "Wechselnde Termine, manuell.",    "card_type": "color", "color": "#EC4899", "image_url": "" }
          ]
        },
        { "key": "ort",  "label": "Adresse",         "type": "textarea", "required": false, "max_length": 200, "placeholder_text": "Straße, PLZ Ort", "show_when": { "field": "typ", "value": "vor_ort" } },
        { "key": "link", "label": "Beitreten-Link",  "type": "url",      "required": false, "placeholder_text": "https://zoom.us/...", "show_when": { "field": "typ", "value": "online" } },
        { "key": "beschreibung", "label": "Beschreibung", "type": "textarea", "required": true, "max_length": 2000, "placeholder_text": "Worum geht es bei diesem Event? Schreib es so, wie du es einem Freund erzählen würdest." },
        {
          "key": "highlights",
          "label": "Highlights",
          "type": "loop",
          "required": false,
          "min_items": 0,
          "max_items": 12,
          "placeholder_text": "Was macht dieses Event besonders?",
          "sub_fields": [
            { "key": "titel",        "label": "Titel",        "type": "text",     "required": true,  "max_length": 70,  "placeholder_text": "z. B. Konkrete Strategie zum Mitnehmen" },
            { "key": "beschreibung", "label": "Beschreibung", "type": "textarea", "required": false, "max_length": 320, "placeholder_text": "1–3 Sätze: Was bekommt der Teilnehmer hier konkret?" }
          ]
        },
        {
          "key": "special_guests",
          "label": "Special Guests",
          "type": "loop",
          "required": false,
          "min_items": 0,
          "max_items": 10,
          "placeholder_text": "Gäste mit Bild und Bio",
          "sub_fields": [
            { "key": "bild",         "label": "Foto (wird quadratisch zugeschnitten)", "type": "image",    "required": true,  "aspect_ratio": "1/1", "placeholder_text": "Quadratisch, min. 400×400 px" },
            { "key": "name",         "label": "Name",          "type": "text",     "required": true,  "max_length": 60,  "placeholder_text": "Vor- und Nachname" },
            { "key": "rolle",        "label": "Rolle / Titel (optional)", "type": "text", "required": false, "max_length": 60, "placeholder_text": "z. B. Coach, Bronze Manager" },
            { "key": "beschreibung", "label": "Kurzbeschreibung (optional)", "type": "textarea", "required": false, "max_length": 240, "placeholder_text": "1–2 Sätze zur Person" }
          ]
        },
        {
          "key": "modus_event",
          "label": "Modus (optional, überschreibt globalen)",
          "type": "card_select",
          "required": false,
          "default_value": "",
          "card_options": [
            { "value": "",       "label": "Übernehmen", "description": "Nutzt deinen globalen Modus.",            "card_type": "color", "color": "#9CA3AF", "image_url": "" },
            { "value": "dunkel", "label": "Dunkel",     "description": "Cinematic für dieses Event.",            "card_type": "color", "color": "#0A0A0A", "image_url": "" },
            { "value": "hell",   "label": "Hell",       "description": "Klar und hell für dieses Event.",        "card_type": "color", "color": "#FFFFFF", "image_url": "" }
          ]
        },
        { "key": "akzentfarbe_event", "label": "Akzentfarbe (optional, überschreibt globale)", "type": "color", "required": false, "default_value": "", "placeholder_text": "Leer = globale Farbe" }
      ]
    }
  ]
}
