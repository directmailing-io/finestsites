            { "value": "einmalig",      "label": "Einmalig",      "description": "Findet genau einmal statt.",         "card_type": "color", "color": "#A78BFA", "image_url": "", "icon": "M12 6v6l4 2M12 22a10 10 0 1 1 0-20 10 10 0 0 1 0 20z" },
            { "value": "taeglich",      "label": "Täglich",       "description": "Jeden Tag zur gleichen Zeit.",       "card_type": "color", "color": "#F59E0B", "image_url": "", "icon": "M3 12h2M12 3v2M12 19v2M19 12h2M5.6 5.6l1.4 1.4M17 17l1.4 1.4M5.6 18.4 7 17M17 7l1.4-1.4M12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10z" },
            { "value": "woechentlich",  "label": "Wöchentlich",   "description": "Jede Woche zur gleichen Zeit.",      "card_type": "color", "color": "#10B981", "image_url": "", "icon": "M3 4h18M3 4v16h18V4M3 9h18M8 4v16M16 4v16" },
            { "value": "monatlich_1x",  "label": "1× pro Monat",  "description": "Einmal im Monat.",                   "card_type": "color", "color": "#06B6D4", "image_url": "", "icon": "M3 5h18v16H3zM3 11h18M8 3v4M16 3v4" },
            { "value": "monatlich_2x",  "label": "2× pro Monat",  "description": "Zweimal im Monat.",                  "card_type": "color", "color": "#0EA5E9", "image_url": "", "icon": "M3 5h18v16H3zM3 11h18M8 3v4M16 3v4M7 15h2M15 15h2" },
            { "value": "individuell",   "label": "Individuell",   "description": "Wechselnde Termine, manuell.",       "card_type": "color", "color": "#EC4899", "image_url": "", "icon": "M3 6h3M9 6h3M15 6h3M3 12h3M9 12h3M15 12h3M3 18h3M9 18h3M15 18h3" }
          ]
        },

        { "key": "ort",  "label": "Adresse",        "type": "textarea", "required": false, "max_length": 200, "placeholder_text": "Straße, PLZ Ort", "show_when": { "field": "typ", "value": "vor_ort" } },
        { "key": "link", "label": "Beitreten-Link", "type": "url",      "required": false, "placeholder_text": "https://zoom.us/...",  "show_when": { "field": "typ", "value": "online" } },

        { "key": "beschreibung", "label": "Beschreibung", "type": "richtext", "required": true, "max_length": 4000, "placeholder_text": "Worum geht es bei diesem Event?" },

        {
          "key": "highlights", "label": "Highlights", "type": "loop", "required": false,
          "min_items": 0, "max_items": 12,
          "placeholder_text": "Was macht dieses Event besonders?",
          "sub_fields": [
            { "key": "titel",        "label": "Titel",        "type": "text",     "required": true,  "max_length": 70,  "placeholder_text": "z. B. Konkrete Strategie zum Mitnehmen" },
            { "key": "beschreibung", "label": "Beschreibung", "type": "textarea", "required": false, "max_length": 320, "placeholder_text": "1–3 Sätze: Was bekommt der Teilnehmer hier konkret?" }
          ]
        },

        {
          "key": "special_guests", "label": "Special Guests", "type": "loop", "required": false,
          "min_items": 0, "max_items": 10,
          "placeholder_text": "Gäste mit Bild und Bio",
          "sub_fields": [
            { "key": "bild",         "label": "Foto (wird quadratisch zugeschnitten)", "type": "image", "required": true, "aspect_ratio": "1/1", "placeholder_text": "Quadratisch, min. 400×400 px" },
            { "key": "name",         "label": "Name",                                 "type": "text",  "required": true,  "max_length": 60, "placeholder_text": "Vor- und Nachname" },
            { "key": "rolle",        "label": "Rolle / Titel (optional)",             "type": "text",  "required": false, "max_length": 60, "placeholder_text": "z. B. Coach, Bronze Manager" },
            { "key": "beschreibung", "label": "Kurzbeschreibung (optional)",          "type": "textarea", "required": false, "max_length": 240, "placeholder_text": "1–2 Sätze zur Person" }
          ]
        },

        {
          "key": "teilnahme_modus", "label": "Wie können Besucher teilnehmen?", "type": "card_select", "required": true,
          "default_value": "direkt",
          "card_options": [
            { "value": "direkt",    "label": "Direkt teilnehmen", "description": "Link bzw. Adresse ist für alle sofort sichtbar.", "card_type": "color", "color": "#10B981", "image_url": "", "icon": "M9 12l2 2 4-4M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z" },
            { "value": "anmeldung", "label": "Mit Anmeldung",     "description": "Besucher füllen ein Formular aus, du schickst Zugang manuell.", "card_type": "color", "color": "#F59E0B", "image_url": "", "icon": "M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2M12 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8z" }
          ]
        },

        { "key": "countdown_anzeigen", "label": "Live-Countdown anzeigen", "type": "toggle", "required": false, "default_value": "ja", "toggle_on_value": "ja", "toggle_off_value": "", "placeholder_text": "Floating Countdown im Event-Hero" },

        {
          "key": "modus_event", "label": "Modus (optional, überschreibt global)", "type": "card_select", "required": false,
          "default_value": "",
          "card_options": [
            { "value": "",       "label": "Übernehmen", "description": "Nutzt deinen globalen Modus.",   "card_type": "color", "color": "#9CA3AF", "image_url": "" },
            { "value": "dunkel", "label": "Dunkel",     "description": "Cinematic für dieses Event.",   "card_type": "color", "color": "#0A0A0A", "image_url": "", "icon": "M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9z" },
            { "value": "hell",   "label": "Hell",       "description": "Klar und hell für dieses Event.", "card_type": "color", "color": "#F59E0B", "image_url": "", "icon": "M12 17a5 5 0 1 0 0-10 5 5 0 0 0 0 10zM12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" }
          ]
        },
        { "key": "akzentfarbe_event", "label": "Akzentfarbe (optional, überschreibt global)", "type": "color", "required": false, "default_value": "", "placeholder_text": "Leer = globale Farbe" }
      ]
